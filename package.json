{
  "name": "enchunted",
  "version": "0.1.14",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:electron\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "build:app": "pnpm run build && electron-builder --dir --publish never",
    "build:mac": "pnpm run build && electron-builder --mac --publish never",
    "build:win": "taskkill /F /IM \"Card Creator.exe\" /T 2>/dev/null || true; taskkill /F /IM electron.exe /T 2>/dev/null || true; sleep 2 && pnpm run build && electron-builder --win --publish never",
    "mac:local": "pnpm run build && pnpm run start:electron",
    "win:local": "pnpm run build && pnpm run start:electron",
    "verify:mac": "pnpm lint && pnpm run build:mac",
    "verify:win": "pnpm lint && pnpm run build:win",
    "start": "vite preview --host 127.0.0.1 --port 4173",
    "start:electron": "electron .",
    "lint": "eslint"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^6.4.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.enchunted.cardcreator",
    "productName": "Card Creator",
    "artifactName": "Card Creator.${ext}",
    "disableDefaultIgnoredFiles": true,
    "npmRebuild": false,
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "directories": {
      "output": "dist-electron"
    }
  }
}
